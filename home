<index.html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>あなたの推しボタン</title>
  <script src="https://cdn.tailwindcss.com"></script>   <!-- Tailwind CSSで簡単に綺麗に -->
  <style>
    body {
      background-color: #0f172a; /* 暗めの背景（剣持風） */
      color: #e2e8f0;
      font-family: 'Helvetica Neue', Arial, sans-serif;
    }
    .tab {
      padding: 12px 24px;
      border-radius: 9999px 9999px 0 0;
      cursor: pointer;
      transition: all 0.2s;
    }
    .tab.active {
      background-color: #ec4899; /* ピンクアクセント */
      color: white;
      font-weight: bold;
    }
    .sound-button {
      background-color: #1e2937;
      border: 2px solid #64748b;
      transition: all 0.2s;
    }
    .sound-button:hover {
      background-color: #ec4899;
      border-color: #f472b6;
      transform: translateY(-2px);
    }
    .sound-button:active {
      transform: scale(0.95);
    }
  </style>
</head>
<body class="min-h-screen py-8">
  <div class="max-w-6xl mx-auto px-4">
    <h1 class="text-4xl font-bold text-center mb-8 text-pink-400">あなたの推しボタン</h1>

    <!-- カテゴリタブ -->
    <div id="tabs" class="flex flex-wrap gap-2 justify-center mb-8 border-b border-slate-700 pb-4">
      <!-- JavaScriptでここにタブを動的に追加 -->
    </div>

    <!-- ボタングリッド -->
    <div id="grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      <!-- ここに音声ボタンが入る -->
    </div>
  </div>

  <script>
    // ここに音声データ（後でJSONにしてもOK）
    const sounds = {
      "挨拶": [
        { name: "おはよう", file: "audio/ohayo.mp3" },
        { name: "こんばんは", file: "audio/konbanwa.mp3" }
      ],
      "笑い": [
        { name: "普通の笑い", file: "audio/warai1.mp3" },
        { name: "爆笑", file: "audio/bakusho.mp3" }
      ],
      "叫び": [
        { name: "うわああ！", file: "audio/scream.mp3" }
      ]
      // ここにどんどん追加
    };

    let currentCategory = "挨拶";

    function renderTabs() {
      const tabsContainer = document.getElementById("tabs");
      tabsContainer.innerHTML = "";
      
      Object.keys(sounds).forEach(category => {
        const tab = document.createElement("div");
        tab.className = `tab px-6 py-3 text-sm ${category === currentCategory ? 'active' : 'bg-slate-800 hover:bg-slate-700'}`;
        tab.textContent = category;
        tab.onclick = () => {
          currentCategory = category;
          renderTabs();
          renderGrid();
        };
        tabsContainer.appendChild(tab);
      });
    }

    function playSound(file) {
      const audio = new Audio(file);
      audio.play().catch(err => console.log("再生エラー:", err));
    }

    function renderGrid() {
      const grid = document.getElementById("grid");
      grid.innerHTML = "";

      sounds[currentCategory].forEach(sound => {
        const btn = document.createElement("button");
        btn.className = "sound-button text-left p-4 rounded-xl h-full flex flex-col justify-between min-h-[100px]";
        btn.innerHTML = `
          <span class="font-medium text-lg">${sound.name}</span>
          <span class="text-xs text-slate-400 mt-2">▶ 再生</span>
        `;
        btn.onclick = () => playSound(sound.file);
        grid.appendChild(btn);
      });
    }

    // 初期化
    renderTabs();
    renderGrid();
  </script>
</body>
</html>
